# Base URL of the StackSift backend API
NEXT_PUBLIC_API_URL=http://localhost:5190

# Public URL of the Next.js frontend (used for OIDC redirect_uri construction)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics (optional in development)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Keycloak OIDC settings
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=stacksift
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=stacksift-frontend

# Mock auth mode — set to "true" to skip real Keycloak and use a fake session.
# This allows the full auth flow to work without Docker.
# Set to "false" (or remove) when Keycloak is running.
NEXT_PUBLIC_AUTH_MOCK=true

# New-user onboarding mode — when "true", the mock sign-in returns a user with
# no organisation so the US-03 onboarding flow is triggered after login.
# Default (false/unset): mock login uses Alice Nguyen who already has an org.
# Requires a server restart after changing.
NEXT_PUBLIC_AUTH_MOCK_NEW_USER=false
